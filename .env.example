# ── Backend de HCE ──────────────────────────────────────────────
# Local (Docker/uvicorn):
#VITE_API_URL=http://localhost:8001/api/v1
# Producción (Render): reemplazar por la URL real del back desplegado, p.ej.
VITE_API_URL=https://healthgrid-hce-backend.onrender.com/api/v1

# ── Modo mocks ──────────────────────────────────────────────────
VITE_USE_MOCKS=false

# ── Core (M10) — SSO ────────────────────────────────────────────
